      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/investimentos",
      "regex": "^/investimentos(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/investimentos(?:/)?$"
    },
    {
      "page": "/login",
