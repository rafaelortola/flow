{
  "name": "financeflow",
  "private": true,
  "scripts": {
    "postinstall": "pnpm db:prepare",
    "dev": "node scripts/ensure-database.js && pnpm --parallel --filter @financeflow/api --filter @financeflow/web dev",
    "db:ensure": "node scripts/ensure-database.js",
    "db:create": "node scripts/create-db.js",
    "build": "pnpm db:prepare && pnpm --filter @financeflow/api build && pnpm --filter @financeflow/web build",
    "test": "pnpm db:prepare && pnpm --filter @financeflow/api test",
    "db:prepare": "pnpm --filter @financeflow/database generate && pnpm --filter @financeflow/database build",
    "db:generate": "pnpm --filter @financeflow/database generate",
    "db:migrate": "pnpm --filter @financeflow/database migrate",
    "db:seed": "pnpm --filter @financeflow/database seed",
    "mcp:postgres": "node scripts/mcp-postgres.js",
    "mcp:postgres:check": "node scripts/mcp-postgres.js --check",
    "validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate.ps1",
    "setup:all": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-all.ps1"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "pg": "^8.13.1",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
