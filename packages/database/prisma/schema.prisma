generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CategoryType {
  INCOME
  EXPENSE
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum CashEntryType {
  IN
  OUT
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  passwordHash String
  name         String
  theme        Theme          @default(SYSTEM)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  categories   Category[]
  incomes      Income[]
  expenses     Expense[]
  debts        Debt[]
  investments  Investment[]
  cashEntries  CashEntry[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      CategoryType
  color     String       @default("#6366f1")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  incomes   Income[]
  expenses  Expense[]

  @@index([userId, type])
  @@map("categories")
}

model Income {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount      Decimal   @db.Decimal(12, 2)
  date        DateTime  @db.Date
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
  @@map("incomes")
}

model Expense {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount      Decimal   @db.Decimal(12, 2)
  date        DateTime  @db.Date
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, date])
  @@map("expenses")
}

model Debt {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  creditor      String
  totalAmount   Decimal       @db.Decimal(12, 2)
  remaining     Decimal       @db.Decimal(12, 2)
  dueDate       DateTime?     @db.Date
  description   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  installments  Installment[]

  @@index([userId])
  @@map("debts")
}

model Installment {
  id        String   @id @default(cuid())
  debtId    String
  debt      Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  number    Int
  amount    Decimal  @db.Decimal(12, 2)
  dueDate   DateTime @db.Date
  paid      Boolean  @default(false)
  paidAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([debtId])
  @@map("installments")
}

model Investment {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  currentValue Decimal  @db.Decimal(12, 2)
  date         DateTime @db.Date
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("investments")
}

model CashEntry {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        CashEntryType
  amount      Decimal       @db.Decimal(12, 2)
  date        DateTime      @db.Date
  description String?
  balance     Decimal       @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, date])
  @@map("cash_entries")
}
