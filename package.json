{
  "name": "financeflow",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @financeflow/api --filter @financeflow/web dev",
    "build": "pnpm --filter @financeflow/database build && pnpm --filter @financeflow/api build && pnpm --filter @financeflow/web build",
    "test": "pnpm --filter @financeflow/api test",
    "db:generate": "pnpm --filter @financeflow/database generate",
    "db:migrate": "pnpm --filter @financeflow/database migrate",
    "db:seed": "pnpm --filter @financeflow/database seed"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
